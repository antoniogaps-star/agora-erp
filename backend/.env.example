# ─── Entorno ──────────────────────────────────────────
APP_ENV=local                 # local | test | staging | production
DEBUG=true

# ─── Base de datos ────────────────────────────────────
# La APP usa un rol NO superusuario (agora_app) para que RLS realmente aísle tenants.
DATABASE_URL=postgresql+asyncpg://agora_app:agora_app@localhost:5432/agora
# Las MIGRACIONES usan el rol dueño (agora), que crea y altera las tablas.
MIGRATION_DATABASE_URL=postgresql+asyncpg://agora:agora@localhost:5432/agora

# ─── Seguridad / JWT ──────────────────────────────────
# Genera una clave fuerte: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_use_a_strong_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# ─── CORS (panel web) ─────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─── IA de dictado de inventario ──────────────────────
# Se intentan en cascada: primero Groq, luego Gemini. Sin ninguna llave el
# endpoint de voz responde 503 y el móvil usa sus reglas locales.
# Groq (preferido, cupo gratuito amplio): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Gemini (respaldo): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
