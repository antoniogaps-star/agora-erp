# ─── Entorno ──────────────────────────────────────────
APP_ENV=local                 # local | test | staging | production
DEBUG=true

# ─── Base de datos ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agora:agora@localhost:5432/agora

# ─── Seguridad / JWT ──────────────────────────────────
# Genera una clave fuerte: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_use_a_strong_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# ─── CORS (panel web) ─────────────────────────────────
CORS_ORIGINS=http://localhost:5173
