# ─── Entorno ──────────────────────────────────────────
APP_ENV=local                 # local | test | staging | production
DEBUG=true

# ─── Base de datos ────────────────────────────────────
# La APP usa un rol NO superusuario (agora_app) para que RLS realmente aísle tenants.
DATABASE_URL=postgresql+asyncpg://agora_app:agora_app@localhost:5432/agora
# Las MIGRACIONES usan el rol dueño (agora), que crea y altera las tablas.
MIGRATION_DATABASE_URL=postgresql+asyncpg://agora:agora@localhost:5432/agora

# ─── Seguridad / JWT ──────────────────────────────────
# Genera una clave fuerte: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_use_a_strong_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# ─── CORS (panel web) ─────────────────────────────────
CORS_ORIGINS=http://localhost:5173
